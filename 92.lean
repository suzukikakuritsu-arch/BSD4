-- ============================================================
-- §12. 具体的な ℓ に対する drop 条件の実装
-- ============================================================

/--
ℓ=2 の場合：2-等分点が全て有理数上にあるか (E1 のケース)
ap mod 2 = 0 が全素数で成立 ⇒ 常に drop される
-/
def drop_ell_2 (A B : ℤ) (p : ℕ) : FrobAction :=
  -- ap(A, B, p) % 2 == 0 ならば ランク候補を削る
  if (ap_val A B p) % 2 = 0 then ⟨1⟩ else ⟨0⟩

/--
ℓ=5 の場合：CM曲線 E3 (y² = x³ - 4) の特異的な ap 分布
ap ≡ 0 (mod 5) が高頻度 (約61%) で発生する現象を drop に反映
-/
def drop_ell_5 (p : ℕ) : FrobAction :=
  -- E3 特有の CM 構造による 5-adic な drop
  if (ap_val 0 (-4) p) % 5 = 0 then ⟨1⟩ else ⟨0⟩

-- ============================================================
-- §13. 数値エビデンスに基づく chain の挙動
-- ============================================================

/--
E1 (rank=0) の解析的証明スケッチ：
すべての p において drop_ell_2 = 1 であるため、
chain はステップ 1 で rank_candidates から {0} へ収束する。
-/
theorem E1_rank_zero_descent (d0 : ℕ) :
    ∃ N, (chain (fun p => drop_ell_2 (-1) 0 p) d0 N) = {0} := by
  -- ここに E1 の 2-等分点が有理数であることを axiom として導入
  sorry

/--
E3 (rank=2) の解析的証明スケッチ：
ℓ=5 における高頻度な drop により、他の rank 候補が排除され、
最終的に L''(1) の粘りと整合する rank 2 付近に候補が絞られる。
-/
theorem E3_rank_two_convergence (d0 : ℕ) :
    ∃ N, 2 ∈ (chain (fun p => drop_ell_5 p) d0 N) := by
  sorry
